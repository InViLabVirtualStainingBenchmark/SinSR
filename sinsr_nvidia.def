Bootstrap: docker
# Matches RockyLinux and CUDA version on CalcUA/Ampere.
# Using CUDA 12.1 in the container — older than the cluster's 12.8,
# torch 2.1.2 was built against cu121 so we pin both to match.
From: nvidia/cuda:12.1.1-cudnn8-devel-rockylinux9

%post
    # mesa-libGL and glib2 are required by OpenCV.
    dnf -y update && \
    dnf -y install \
        python3-pip \
        python3-devel \
        git \
        mesa-libGL \
        glib2 && \
    dnf clean all

    python3 -m pip install --no-cache-dir --upgrade pip

    # Install torch first, pinned to the cu121 wheel.
    # Must be done before other packages that depend on torch.
    python3 -m pip install --no-cache-dir \
        torch==2.1.2 torchvision==0.16.2 \
        --index-url https://download.pytorch.org/whl/cu121

    # Wheel needed to build some packages from source
    python3 -m pip install --no-cache-dir wheel

    # SinSR dependencies.
    # transformers is pinned to 4.38.2 — newer versions require
    # torch.utils._pytree.register_pytree_node which was only added in torch 2.3+.
    # xformers is omitted — SinSR runs without it.
    python3 -m pip install --no-cache-dir \
        albumentations==1.3.1 \
        einops==0.8.2 \
        loguru==0.7.3 \
        lpips==0.1.4 \
        numpy==1.26.4 \
        omegaconf==2.3.0 \
        openai-clip==1.0.1 \
        opencv-python==4.8.1.78 \
        pillow==11.3.0 \
        pyiqa==0.1.15.post2 \
        scikit-image==0.24.0 \
        scipy==1.13.1 \
        timm==1.0.26 \
        tqdm==4.67.3 \
        matplotlib==3.9.4 \
        pyyaml==6.0.3 \
        transformers==4.38.2

%environment
    export PYTHONUNBUFFERED=1
